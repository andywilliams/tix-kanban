# OpenAI API Key for semantic memory embeddings
# Get your API key from: https://platform.openai.com/api-keys
# If not set, semantic search will be disabled and keyword search will be used as fallback
OPENAI_API_KEY=sk-your-api-key-here

# lgtm binary path for automated code review pipeline
# Default: "lgtm" (assumes lgtm is in PATH)
# Can be set to absolute path like: /usr/local/bin/lgtm
LGTM_BINARY_PATH=lgtm
